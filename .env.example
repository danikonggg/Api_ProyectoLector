# API Lector - Variables de entorno
# Copia este archivo a .env y ajusta los valores

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL
# DB_LOG_QUERIES: true = ver queries en consola (dev). false = solo errores
# DB_LOG_QUERY_MAX_LENGTH: caracteres máximos del SQL en logs. 0 = sin truncar, default 2000
# DB_POOL_SIZE: conexiones máximas en el pool (default 20; sube solo si medís cuello de botella; ~200 usuarios concurrentes suele ir con 80+)
# DB_POOL_IDLE_TIMEOUT_MS: ms sin uso antes de cerrar un cliente del pool (default 120000 = 2 min; menos reconexiones que 30s)

# OPCIÓN A - Supabase (recomendado para producción/cloud)
# Obtén la cadena de conexión en: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Usa "Session mode" (pooler) para servidores o "Transaction mode" para serverless
# Ejemplo: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DATABASE_URL=

# OPCIÓN B - PostgreSQL local (si DATABASE_URL no está definida)
DB_POOL_SIZE=20
DB_POOL_IDLE_TIMEOUT_MS=120000
DB_LOG_QUERIES=true
DB_LOG_QUERY_MAX_LENGTH=2000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=api_lector

# Auto-archivar licencias vencidas:
# cada cuánto (ms) se ejecuta un job interno que mueve vencidas a tabla histórica
# y las elimina de la tabla activa.
LICENCIAS_AUTO_ARCHIVAR_INTERVAL_MS=3600000

# --- Redis (colas BullMQ + caché JWT; sin REDIS_URL/REDIS_HOST = cola desactivada, carga de libros síncrona) ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Throttle: peticiones por minuto. Con JWT se cuenta por usuario (user:id); sin token, por IP (ip:...).
THROTTLE_LIMIT_PER_MIN=2000

# Caché en memoria del resultado de JwtStrategy (ms). 0 = desactivado (máx coherencia tras desactivar usuario).
# En multi-instancia usar Redis + TTL corto o 0 aquí.
# JWT_PERSONA_CACHE_TTL_MS=0

# Logs: nestjs-pino (JSON en consola). HTTP: una línea tipo "GET /ruta 200 12ms" si LOG_HTTP_SUMMARY=true (default).
# LOG_FILE: copia los mismos logs a archivo (ej. logs/api.log); la carpeta se crea si no existe.
# LOG_HTTP_SUMMARY=false = mensajes HTTP con más detalle (req/res serializados algo más verbosos).
# HTTP_AUTO_LOGGING=false desactiva el log automático por request de pino-http.
# LOG_LEVEL=info
# LOG_FILE=logs/api.log
# LOG_HTTP_SUMMARY=true
# HTTP_AUTO_LOGGING=true

# OpenTelemetry OTLP HTTP (trazas → Jaeger en observability_Lector :4318; UI http://localhost:16686)
# Con el stack de observabilidad levantado: OTEL_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=api-lector
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Worker Bull: concurrencia de jobs libros-import
# LIBROS_IMPORT_WORKER_CONCURRENCY=2

# Lock Redis por libro en import (segundos). Default 86400 (24h). Mínimo 60, máximo 7 días.
# LIBRO_IMPORT_LOCK_TTL_SEC=86400

# Auditoría HTTP global (interceptor): POST/PUT/PATCH/DELETE exitosos → audit_log
# AUDIT_HTTP_ENABLED=false desactiva el hook. AUDIT_HTTP_SKIP_PATHS: rutas separadas por coma (default incluye /auth/login para no duplicar log de login)
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_SKIP_PATHS=/auth/login

# JWT (OBLIGATORIO en producción - mínimo 32 caracteres aleatorios)
JWT_SECRET=tu-secret-key-cambiar-en-produccion
JWT_EXPIRES_IN=24h

# CORS - Orígenes permitidos (separados por coma). En desarrollo puede ser * o vacío para permitir todo
# Ejemplo producción: https://app.tudominio.com,https://admin.tudominio.com
CORS_ORIGINS=

# Groq AI (obtén tu API key en https://console.groq.com)
GROQ_API_KEY=

# Contraseña mínima (opcional, default 6)
# PASSWORD_MIN_LENGTH=6

# DB_LOG_QUERIES: true = ver queries SQL (dev). false = solo errores
