# API Lector - Variables de entorno
# Copia este archivo a .env y ajusta los valores

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL
# DB_LOG_QUERIES: true = ver queries en consola (dev). false = solo errores
# DB_LOG_QUERY_MAX_LENGTH: caracteres máximos del SQL en logs. 0 = sin truncar, default 2000
# DB_POOL_SIZE: conexiones máximas en el pool (default 20; sube solo si medís cuello de botella; ~200 usuarios concurrentes suele ir con 80+)
# DB_POOL_IDLE_TIMEOUT_MS: ms sin uso antes de cerrar un cliente del pool (default 120000 = 2 min; menos reconexiones que 30s)

# OPCIÓN A - Supabase (recomendado para producción/cloud)
# Obtén la cadena de conexión en: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Usa "Session mode" (pooler) para servidores o "Transaction mode" para serverless
# Ejemplo: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DATABASE_URL=
# Si usas DATABASE_URL con SSL:
# DB_SSL_ENABLED=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# OPCIÓN B - PostgreSQL local (si DATABASE_URL no está definida)
DB_POOL_SIZE=20
DB_POOL_IDLE_TIMEOUT_MS=120000
DB_LOG_QUERIES=true
DB_LOG_QUERY_MAX_LENGTH=2000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=api_lector

# Auto-archivar licencias vencidas:
# cada cuánto (ms) se ejecuta un job interno que mueve vencidas a tabla histórica
# y las elimina de la tabla activa.
LICENCIAS_AUTO_ARCHIVAR_INTERVAL_MS=3600000

# --- Redis (obligatorio si NODE_ENV=production: colas Bull + caché; sin Redis en dev: libros se procesan en el mismo proceso) ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Throttle: peticiones por minuto. Con JWT se cuenta por usuario (user:id); sin token, por IP (ip:...).
# 120 req/min es el default seguro (≈2 req/s). Sube con THROTTLE_LIMIT_PER_MIN si tus clientes legítimos lo necesitan.
THROTTLE_LIMIT_PER_MIN=120

# Caché del perfil JWT (ms). 30000 = 30s (default). 0 = desactivado.
# Con Redis configurado usa Redis; sin Redis usa memoria en proceso (no compartida entre instancias).
JWT_PERSONA_CACHE_TTL_MS=30000

# Retención de logs de auditoría (días). Registros más antiguos se eliminan cada día a las 2 AM.
# AUDIT_RETENTION_DAYS=90

# Logs: nestjs-pino (JSON en consola). HTTP: una línea tipo "GET /ruta 200 12ms" si LOG_HTTP_SUMMARY=true (default).
# LOG_FILE: copia los mismos logs a archivo (ej. logs/api.log); la carpeta se crea si no existe.
# LOG_HTTP_SUMMARY=false = mensajes HTTP con más detalle (req/res serializados algo más verbosos).
# HTTP_AUTO_LOGGING=false desactiva el log automático por request de pino-http.
# LOG_LEVEL=info
# LOG_FILE=logs/api.log
# LOG_HTTP_SUMMARY=true
# HTTP_AUTO_LOGGING=true

# OpenTelemetry OTLP HTTP (trazas → Jaeger en observability_Lector :4318; UI http://localhost:16686)
# Con el stack de observabilidad levantado: OTEL_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=api-lector
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Worker Bull: concurrencia de jobs libros-import
# LIBROS_IMPORT_WORKER_CONCURRENCY=2

# Lock Redis por libro en import (segundos). Default 86400 (24h). Mínimo 60, máximo 7 días.
# LIBRO_IMPORT_LOCK_TTL_SEC=86400

# Auditoría HTTP global (interceptor): POST/PUT/PATCH/DELETE exitosos → audit_log
# AUDIT_HTTP_ENABLED=false desactiva el hook. AUDIT_HTTP_SKIP_PATHS: rutas separadas por coma (default incluye /auth/login para no duplicar log de login)
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_SKIP_PATHS=/auth/login

# Token técnico: obligatorio (excepto NODE_ENV=test). Enviar en header: x-metrics-token
# METRICS_TOKEN=genera-un-string-largo-aleatorio
# METRICS_ALLOW_UNPROTECTED: ignorado; en producción no se permite sin token (validación en env + controller).

# JWT: mínimo 32 caracteres aleatorios (sin palabras de ejemplo: fallará validateEnv)
JWT_SECRET=
# Access token (corto)
JWT_EXPIRES_IN=2d
# Refresh token cuando NO se marca "mantener sesión"
JWT_REFRESH_EXPIRES_IN_SHORT=2d
# Refresh token (largo)
JWT_REFRESH_EXPIRES_IN=50d
# OBLIGATORIO en producción: secreto exclusivo para refresh token.
# Usar el mismo que JWT_SECRET crea un único punto de falla — si el access secret se filtra, también los refresh tokens.
# JWT_REFRESH_SECRET=

# CORS - Orígenes permitidos (separados por coma). En desarrollo puede ser * o vacío para permitir todo
# Ejemplo producción: https://app.tudominio.com,https://admin.tudominio.com
CORS_ORIGINS=

# Groq AI (obtén tu API key en https://console.groq.com)
GROQ_API_KEY=

# Supabase Storage (PDFs)
# Usa URL + service role key del proyecto para cargas desde backend.
# En NODE_ENV=production son obligatorios (validateEnv).
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=api-lector-pdfs
# TTL (segundos) para URLs firmadas de descarga PDF
# SUPABASE_SIGNED_URL_TTL_SECONDS=300

# Glosario por segmento: precarga en segundo plano al terminar de importar un libro (true/false)
GLOSSARY_PRELOAD_ON_IMPORT=true

# Contraseña mínima (opcional, default 6)
# PASSWORD_MIN_LENGTH=6

# ---------------------------------------------------------------
# Correo (Nodemailer) — Recuperación de contraseña
# ---------------------------------------------------------------
# SMTP_HOST: servidor SMTP (ej. smtp.gmail.com, smtp.sendgrid.net)
# SMTP_PORT: 587 (STARTTLS) o 465 (SSL)
# SMTP_SECURE: true solo si SMTP_PORT=465
# SMTP_USER / SMTP_PASS: credenciales SMTP
# SMTP_FROM: dirección del remitente
# FRONTEND_URL: URL base del frontend para armar el enlace de reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=no-reply@apilector.com
FRONTEND_URL=http://localhost:3000

# Primer admin (script: npm run seed:admin) — nunca con valores por defecto en el repo
# SEED_ADMIN_EMAIL=admin@tu-dominio.com
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NOMBRE=Admin
# SEED_ADMIN_APELLIDO_PATERNO=Sistema

# DB_LOG_QUERIES: true = ver queries SQL (dev). false = solo errores
