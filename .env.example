# API Lector - Variables de entorno
# Copia este archivo a .env y ajusta los valores

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL
# DB_LOG_QUERIES: true = ver queries en consola (dev). false = solo errores
# DB_LOG_QUERY_MAX_LENGTH: caracteres máximos del SQL en logs. 0 = sin truncar, default 2000
# DB_POOL_SIZE: conexiones máximas en el pool (para ~200 usuarios concurrentes usar 80+; PostgreSQL max_connections debe ser >= este valor)

# OPCIÓN A - Supabase (recomendado para producción/cloud)
# Obtén la cadena de conexión en: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Usa "Session mode" (pooler) para servidores o "Transaction mode" para serverless
# Ejemplo: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DATABASE_URL=

# OPCIÓN B - PostgreSQL local (si DATABASE_URL no está definida)
DB_POOL_SIZE=80
DB_LOG_QUERIES=true
DB_LOG_QUERY_MAX_LENGTH=2000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=api_lector

# Auto-archivar licencias vencidas:
# cada cuánto (ms) se ejecuta un job interno que mueve vencidas a tabla histórica
# y las elimina de la tabla activa.
LICENCIAS_AUTO_ARCHIVAR_INTERVAL_MS=3600000

# Throttle: peticiones por minuto por IP (default 2000 para aguantar pruebas de carga de 1000 usuarios)
THROTTLE_LIMIT_PER_MIN=2000

# Auditoría HTTP global (interceptor): POST/PUT/PATCH/DELETE exitosos → audit_log
# AUDIT_HTTP_ENABLED=false desactiva el hook. AUDIT_HTTP_SKIP_PATHS: rutas separadas por coma (default incluye /auth/login para no duplicar log de login)
# AUDIT_HTTP_ENABLED=true
# AUDIT_HTTP_SKIP_PATHS=/auth/login

# JWT (OBLIGATORIO en producción - mínimo 32 caracteres aleatorios)
JWT_SECRET=tu-secret-key-cambiar-en-produccion
JWT_EXPIRES_IN=24h

# CORS - Orígenes permitidos (separados por coma). En desarrollo puede ser * o vacío para permitir todo
# Ejemplo producción: https://app.tudominio.com,https://admin.tudominio.com
CORS_ORIGINS=

# Groq AI (obtén tu API key en https://console.groq.com)
GROQ_API_KEY=

# Contraseña mínima (opcional, default 6)
# PASSWORD_MIN_LENGTH=6

# DB_LOG_QUERIES: true = ver queries SQL (dev). false = solo errores
